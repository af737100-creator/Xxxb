<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.recorder.app">

    <!-- الصلاحيات الأساسية لتسجيل المكالمات والبدء التلقائي -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    
    <!-- مطلوب في أندرويد 13 (Tiramisu)+ لإظهار إشعارات الخدمات -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- مطلوب في أندرويد 14 (UpsideDownCake)+ للخدمات الأمامية التي تستخدم الميكروفون -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/ic_menu_save"
        android:label="مسجل المكالمات الدائم"
        android:roundIcon="@android:drawable/ic_menu_save"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.DarkActionBar">

        <!-- واجهة التفاعل الأمامية -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- الخدمة الخلفية المستمرة للتسجيل -->
        <service 
            android:name=".CallService"
            android:foregroundServiceType="microphone"
            android:exported="false" />

        <!-- مستقبل البث لإعادة تشغيل مسجل المكالمات تلقائياً عند فتح الهاتف -->
        <receiver 
            android:name=".BootReceiver" 
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>