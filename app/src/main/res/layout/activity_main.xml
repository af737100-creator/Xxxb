<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="مسجل المكالمات الذكي"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A202C"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        android:elevation="4dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="حالة الخدمة: غير نشطة"
            android:textColor="#718096"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#FF5722"
            android:textColor="#FFFFFF"
            android:text="تشغيل الخدمة التلقائية" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="المكالمات المسجلة المحفوظة"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#2D3748"
        android:layout_marginBottom="8dp" />

    <ListView
        android:id="@+id/listViewRecordings"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#E2E8F0"
        android:dividerHeight="1dp"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:id="@+id/playerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#EDF2F7"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvPlayingName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="جاري تشغيل: ..."
            android:textSize="12sp"
            android:textColor="#4A5568"
            android:ellipsize="end"
            android:singleLine="true" />

        <Button
            android:id="@+id/btnStopPlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="إيقاف"
            android:textSize="12sp"
            android:backgroundTint="#E53935"
            android:textColor="#FFFFFF" />
    </LinearLayout>
</LinearLayout>